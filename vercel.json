{
  "version": 2,
  "builds": [
    {
      "src": "server-entry.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "build/client/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/build/client/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server-entry.js"
    }
  ],
  "installCommand": "npm install --legacy-peer-deps"
}
